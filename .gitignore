# ========================================================
# XJ-GPT 协议注册机 · .gitignore
# ========================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.venv/
venv/
env/

# ---- IDE / OS ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ---- 运行时生成的批次归档(每次注册自动产出,体积大) ----
accounts/

# ---- 运行时生成的日志 ----
注册日志/

# ---- 本地杂项 ----
*.log
*.bak
*.tmp

# ---- 外部工具 (用户自行下载,与注册机不直接耦合) ----
CLIProxyAPI_*/

# ---- Claude Code 会话数据 ----
.claude/

# ---- 含真实凭据/与项目无直接关联的本地配置 ----
config/sms.py
config/cliproxy.py
config/*_local.py
