# ========================================================
# XJ-GPT 协议注册机 · .gitignore
# ========================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.venv/
venv/
env/

# ---- IDE / OS ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ---- 运行时生成的批次归档(每次注册自动产出,体积大) ----
accounts/

# ---- 运行时生成的日志 ----
注册日志/

# ---- 本地杂项 ----
*.log
*.bak
*.tmp
