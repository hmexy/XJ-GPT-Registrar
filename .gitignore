# ========================================================
# XJ-GPT 协议注册机 · .gitignore
# 这些文件含敏感数据(凭据/token/邮箱密码),严禁上传
# ========================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.venv/
venv/
env/

# ---- IDE / OS ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ---- 敏感数据:输入邮箱池 ----
# 含 password / refresh_token
用于注册的邮箱.json
用于注册的邮箱.txt

# ---- 敏感数据:注册成功的账号 ----
# 含 access_token / TOTP secret / 用户信息
注册成功的邮箱.json
注册成功的邮箱.txt
注册成功的token.txt

# ---- 敏感数据:账号归档目录 ----
# 每个批次都有完整的账号 JSON
accounts/

# ---- 敏感数据:运行日志 ----
# 可能含请求/响应体里的 token
注册日志/

# ---- 敏感数据:配置里的凭据 ----
# flow_trigger.py 里有 Bearer + admin_session cookie
# 模板见 flow_trigger.example.py
config/flow_trigger.py

# ---- 敏感数据:历史账号快照 ----
# 这个 HTML 里嵌入了实际账号的 SNAPSHOT JSON
accounts_viewer.html

# ---- 本地杂项 ----
*.log
*.bak
*.tmp
